# Anthropic API key for Claude content generation
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of competitor sitemap URLs
COMPETITOR_SITEMAPS=https://example-pt-clinic.com/sitemap.xml,https://another-pt-blog.com/sitemap.xml

# CMS publishing configuration
# Options: wordpress, webflow, generic
CMS_TYPE=wordpress

# WordPress settings
WP_URL=https://yoursite.com
WP_USER=your_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Webflow settings
WEBFLOW_API_KEY=
WEBFLOW_COLLECTION_ID=

# Generic CMS settings
GENERIC_CMS_URL=
GENERIC_CMS_KEY=
